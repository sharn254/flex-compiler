rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // User Profiles
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'displayName', 'photoURL', 'lastLogin']) &&
               data.uid == userId &&
               data.email is string &&
               data.email.size() <= 256;
      }

      allow get: if isSignedIn();
      allow create, update: if isOwner(userId) && isValidUser(incoming());
    }

    // Projects
    match /projects/{projectId} {
      function isValidProject(data) {
        return data.keys().hasAll(['name', 'language', 'code', 'userId', 'updatedAt']) &&
               data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
               data.language is string && data.language.size() <= 50 &&
               data.code is string && data.code.size() <= 1048576 && // 1MB limit check
               data.userId == request.auth.uid &&
               isValidId(data.userId);
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid);
      
      allow create: if isSignedIn() && isValidProject(incoming()) && incoming().keys().hasAll(['createdAt']) && incoming().createdAt == request.time;
      
      allow update: if isOwner(existing().userId) && 
                      isValidProject(incoming()) && 
                      incoming().userId == existing().userId &&
                      incoming().updatedAt == request.time;
                      
      allow delete: if isOwner(existing().userId);
    }
  }
}
