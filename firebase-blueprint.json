{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A code project saved by a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "userId": { "type": "string" },
        "language": { "type": "string" },
        "code": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "userId", "language", "code", "createdAt", "updatedAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "User projects"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    }
  }
}
